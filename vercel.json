{
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
{
  "rewrites": [
    { "source": "/apply/(.*)", "destination": "/apply.html" },
    { "source": "/take-assessment/(.*)", "destination": "/take-assessment.html" }
  ]
}
