{
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
{
  "rewrites": [
    { "source": "/apply/:id", "destination": "/apply.html" },
    { "source": "/take-assessment/:id", "destination": "/take_assessment.html" },
    { "source": "/offer-response/:id/:action", "destination": "/offer_response.html" }
  ]
}
